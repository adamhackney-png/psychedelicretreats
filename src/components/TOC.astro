---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const items = headings.filter((h) => h.depth === 2);
---

{items.length > 1 && (
  <nav aria-label="Table of contents" class="rounded-lg border border-line bg-cream-dark/50 p-5">
    <p class="text-xs font-semibold uppercase tracking-wide text-charcoal-soft">On this page</p>
    <ul class="mt-3 space-y-2 text-sm">
      {items.map((heading) => (
        <li>
          <a href={`#${heading.slug}`} class="text-forest-600 hover:text-forest-700 hover:underline">{heading.text}</a>
        </li>
      ))}
    </ul>
  </nav>
)}
