---
import { breadcrumbJsonLd } from '../lib/seo';

interface Crumb {
  name: string;
  path: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
const allItems = [{ name: 'Home', path: '/' }, ...items];
const jsonLd = breadcrumbJsonLd(allItems);
---

<nav aria-label="Breadcrumb" class="mx-auto max-w-7xl px-4 py-4 text-sm sm:px-6 lg:px-8">
  <ol class="flex flex-wrap items-center gap-1.5 text-charcoal-soft">
    {allItems.map((item, index) => (
      <li class="flex items-center gap-1.5">
        {index > 0 && <span aria-hidden="true">/</span>}
        {index === allItems.length - 1 ? (
          <span class="text-charcoal" aria-current="page">{item.name}</span>
        ) : (
          <a href={item.path} class="hover:text-forest-700 hover:underline">{item.name}</a>
        )}
      </li>
    ))}
  </ol>
</nav>
<script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
