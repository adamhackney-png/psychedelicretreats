---
import { CRISIS_SUPPORT } from '../lib/site';
---

<div class="flex items-start gap-3 rounded-lg border border-terracotta-300 bg-terracotta-100/40 px-4 py-3 text-sm text-charcoal">
  <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 flex-none text-terracotta-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0 3.75h.008v.008H12v-.008ZM21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
  </svg>
  <p>
    If you or someone you know is struggling, support is available right now:
    <a href={CRISIS_SUPPORT.url} class="font-semibold underline">{CRISIS_SUPPORT.name} {CRISIS_SUPPORT.phone}</a>,
    24/7. In an emergency, call 000.
  </p>
</div>
