---
import { SITE } from '../lib/site';

const columns = [
  {
    heading: 'Explore',
    links: [
      { label: 'Retreats', href: '/retreats/' },
      { label: 'Clinics', href: '/clinics/ketamine/' },
      { label: 'Integration', href: '/integration/' },
      { label: 'Destinations', href: '/destinations/' },
      { label: 'Guides', href: '/guides/' },
      { label: 'News', href: '/news/' },
    ],
  },
  {
    heading: 'Tools',
    links: [
      { label: 'Retreat Match Quiz', href: '/tools/retreat-match/' },
      { label: 'Cost Calculator', href: '/tools/cost-calculator/' },
      { label: 'Legality Map', href: '/tools/legality-map/' },
      { label: 'For Operators', href: '/for-operators/' },
    ],
  },
  {
    heading: 'About',
    links: [
      { label: 'About Us', href: '/about/' },
      { label: 'Editorial Policy', href: '/editorial-policy/' },
      { label: 'Medical Disclaimer', href: '/medical-disclaimer/' },
      { label: 'Contact', href: '/contact/' },
    ],
  },
  {
    heading: 'Legal',
    links: [
      { label: 'Terms of Use', href: '/terms/' },
      { label: 'Privacy Policy', href: '/privacy/' },
      { label: 'Newsletter', href: '/newsletter/' },
    ],
  },
];
---

<footer class="mt-24 border-t border-line bg-cream-dark">
  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
      {columns.map((col) => (
        <div>
          <h3 class="font-sans text-sm font-semibold uppercase tracking-wide text-forest-700">{col.heading}</h3>
          <ul class="mt-3 space-y-2">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-charcoal-soft hover:text-forest-700">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 space-y-3 border-t border-line pt-8 text-xs leading-relaxed text-charcoal-soft">
      <p>
        <strong class="font-semibold text-charcoal">{SITE.name}</strong> is an independent publisher and directory.
        We are not a medical provider, retreat operator, booking agent, or referrer, and we do not receive
        prescriber referrals. Nothing on this site is medical advice — see our{' '}
        <a href="/medical-disclaimer/" class="underline">medical disclaimer</a>. Some listings include affiliate
        links, marked accordingly — see our <a href="/editorial-policy/" class="underline">editorial policy</a>.
      </p>
      <p>ABN: [ABN PLACEHOLDER] · Contact: <a href={`mailto:${SITE.contactEmail}`} class="underline">{SITE.contactEmail}</a></p>
      <p>&copy; {new Date().getFullYear()} {SITE.name}. All rights reserved.</p>
    </div>
  </div>
</footer>
