---
interface Props {
  listingSlug: string;
}

const { listingSlug } = Astro.props;
---

<div class="flex flex-col items-start gap-3 rounded-lg border border-terracotta-300 bg-terracotta-100/40 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
  <p class="text-sm text-charcoal">
    <strong class="font-semibold">Unclaimed listing.</strong> Are you affiliated with this retreat or service?
    Claim it free to keep details accurate and add operator-verified information.
  </p>
  <a
    href={`/for-operators/#claim?listing=${listingSlug}`}
    class="flex-none rounded-lg bg-terracotta-500 px-4 py-2 text-sm font-semibold text-cream transition hover:bg-terracotta-600"
  >
    Claim it free
  </a>
</div>
