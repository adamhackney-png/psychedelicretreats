---
import SourcesList from './SourcesList.astro';

interface Props {
  summary: string;
  details: string;
  sourceUrls: string[];
}

const { summary, details, sourceUrls } = Astro.props;
const sources = sourceUrls.map((url, i) => ({ title: `Source ${i + 1}`, url }));
---

<section class="rounded-xl border border-forest-300 bg-forest-50 p-6">
  <div class="flex items-center gap-2">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
    </svg>
    <h3 class="text-sm font-semibold uppercase tracking-wide text-forest-700">Legal status</h3>
  </div>
  <p class="mt-3 font-serif text-lg font-medium text-forest-900">{summary}</p>
  <p class="mt-2 text-sm leading-relaxed text-charcoal-soft">{details}</p>
  <p class="mt-3 text-xs text-charcoal-soft">
    General information, not legal advice — always verify current law before travelling.
  </p>
  <div class="mt-4">
    <SourcesList sources={sources} compact />
  </div>
</section>
