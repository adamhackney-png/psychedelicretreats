---
interface Props {
  vetting: {
    legalJurisdiction: 'stated' | 'unverified';
    medicalScreening: 'stated' | 'unverified';
    facilitatorExperience: 'stated' | 'unverified';
    emergencyProtocol: 'stated' | 'unverified';
    independentReviews: 'stated' | 'unverified';
    pricingDisclosed: 'stated' | 'unverified';
  };
}

const { vetting } = Astro.props;

const LABELS: Record<keyof Props['vetting'], string> = {
  legalJurisdiction: 'Legal jurisdiction disclosed',
  medicalScreening: 'Medical / psychological screening process',
  facilitatorExperience: 'Facilitator training & experience',
  emergencyProtocol: 'Emergency protocol in place',
  independentReviews: 'Independent reviews findable',
  pricingDisclosed: 'Pricing disclosed upfront',
};

const items = (Object.keys(LABELS) as (keyof Props['vetting'])[]).map((key) => ({
  label: LABELS[key],
  status: vetting[key],
}));
---

<div class="rounded-lg border border-line bg-white p-5">
  <h3 class="text-sm font-semibold uppercase tracking-wide text-forest-700">Vetting checklist</h3>
  <p class="mt-1 text-xs text-charcoal-soft">
    Self-reported by the operator's public materials and reviewed by us where possible. "Stated" means the
    operator publicly discloses this; it is not independent verification.
  </p>
  <ul class="mt-4 space-y-2.5">
    {items.map((item) => (
      <li class="flex items-start gap-2.5 text-sm">
        {item.status === 'stated' ? (
          <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-4 w-4 flex-none text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
          </svg>
        ) : (
          <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-4 w-4 flex-none text-charcoal-soft/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="9" stroke-dasharray="2 3" />
          </svg>
        )}
        <span class={item.status === 'stated' ? 'text-charcoal' : 'text-charcoal-soft'}>
          {item.label}
          <span class="ml-1.5 text-xs font-medium">
            {item.status === 'stated' ? '— Stated ✓' : '— Not yet verified'}
          </span>
        </span>
      </li>
    ))}
  </ul>
</div>
