---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="This page doesn't exist." noindex={true}>
  <section class="mx-auto flex min-h-[50vh] max-w-2xl flex-col items-center justify-center px-4 text-center sm:px-6 lg:px-8">
    <p class="font-serif text-6xl font-medium text-forest-900">404</p>
    <h1 class="mt-4 font-serif text-2xl font-medium text-forest-900">We couldn't find that page</h1>
    <p class="mt-3 text-charcoal-soft">
      The page may have moved, or the listing may no longer be current. Try searching, or head back to the
      homepage.
    </p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a href="/" class="rounded-lg bg-forest-600 px-5 py-2.5 text-sm font-semibold text-cream hover:bg-forest-700">Go to homepage</a>
      <a href="/retreats/" class="rounded-lg border border-line px-5 py-2.5 text-sm font-semibold text-charcoal hover:bg-cream-dark">Browse retreats</a>
    </div>
  </section>
</BaseLayout>
