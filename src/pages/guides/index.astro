---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { itemListJsonLd } from '../../lib/seo';

const guides = (await getCollection('guides')).sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const jsonLd = itemListJsonLd(guides.filter((g) => !g.data.draft).map((g) => ({ name: g.data.title, path: `/guides/${g.id}/` })));
---

<BaseLayout
  title="Guides — Psychedelic Retreats & Legal Information"
  description="In-depth, sourced guides to legal psychedelic retreats, Australian clinical pathways, safety, and integration."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={[{ name: 'Guides', path: '/guides/' }]} />

  <section class="mx-auto max-w-7xl px-4 pb-8 sm:px-6 lg:px-8">
    <h1 class="font-serif text-3xl font-medium text-forest-900 sm:text-4xl">Guides</h1>
    <p class="mt-3 max-w-2xl text-charcoal-soft">
      Sourced, informational guides — not medical or legal advice. See each guide's sources and last-reviewed date.
    </p>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {guides.map((guide) => (
        <a href={`/guides/${guide.id}/`} class="relative rounded-lg border border-line bg-white p-5 shadow-sm transition hover:shadow-md">
          {guide.data.draft && (
            <span class="absolute right-4 top-4 rounded-full bg-terracotta-100 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wide text-terracotta-600">
              Draft
            </span>
          )}
          <p class="text-xs font-semibold uppercase tracking-wide text-terracotta-600">{guide.data.cluster ?? 'Guide'}</p>
          <h2 class="mt-1 font-serif text-lg font-medium text-forest-900">{guide.data.title}</h2>
          <p class="mt-2 text-sm text-charcoal-soft">{guide.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
