---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { DESTINATION_COST_PROFILES, PRICE_BAND_RANGES_AUD, INSURANCE_RANGE_AUD } from '../../../data/cost-calculator-data';

const calculatorData = {
  destinations: DESTINATION_COST_PROFILES,
  priceBands: PRICE_BAND_RANGES_AUD,
  insurance: INSURANCE_RANGE_AUD,
};
---

<BaseLayout
  title="Retreat Cost Calculator (AUD)"
  description="Estimate the total cost of a psychedelic retreat from Australia — program price, flights, insurance, and buffer nights, in AUD."
>
  <Breadcrumbs items={[{ name: 'Tools', path: '/tools/retreat-match/' }, { name: 'Cost Calculator', path: '/tools/cost-calculator/' }]} />

  <section class="mx-auto max-w-3xl px-4 pb-8 sm:px-6 lg:px-8">
    <h1 class="font-serif text-3xl font-medium text-forest-900 sm:text-4xl">Retreat Cost Calculator</h1>
    <p class="mt-3 text-charcoal-soft">
      A rough total for an Australian traveller, in AUD — program price, return flights, travel insurance, and
      buffer accommodation nights. Every figure here is an estimate; see our{' '}
      <a href="/guides/how-much-does-a-psychedelic-retreat-cost/" class="text-forest-600 underline">cost guide</a>{' '}
      for the full breakdown and always confirm current pricing directly with an operator.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-4 pb-8 sm:px-6 lg:px-8">
    <div class="rounded-lg border border-line bg-white p-6" id="cost-calculator" data-calculator>
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label for="cc-destination" class="text-sm font-medium text-charcoal">Destination</label>
          <select id="cc-destination" class="mt-1 w-full rounded-md border border-line px-3 py-2 text-sm">
            {calculatorData.destinations.map((d) => <option value={d.slug}>{d.name}</option>)}
          </select>
        </div>
        <div>
          <label for="cc-price-band" class="text-sm font-medium text-charcoal">Retreat price band</label>
          <select id="cc-price-band" class="mt-1 w-full rounded-md border border-line px-3 py-2 text-sm">
            {Object.entries(calculatorData.priceBands).map(([value, band]) => <option value={value}>{band.label}</option>)}
          </select>
        </div>
      </div>

      <div class="mt-6 space-y-3 rounded-lg bg-cream-dark/50 p-5" id="cc-results">
        <!-- Populated by client script -->
      </div>

      <p class="mt-4 text-xs text-charcoal-soft">
        Estimates only, based on figures published on this site's destination pages at time of writing — not a
        quote. Excludes pre/post travel, domestic connections, and any add-ons not bundled into the program price.
      </p>
    </div>
  </section>
</BaseLayout>

<script is:inline type="application/json" id="cc-data" set:html={JSON.stringify(calculatorData)} />
<script>
  interface DestinationCostProfile {
    slug: string;
    name: string;
    flightLowAUD: number;
    flightHighAUD: number;
    typicalDurationDays: number;
    bufferNights: number;
  }
  interface CalculatorData {
    destinations: DestinationCostProfile[];
    priceBands: Record<string, { low: number; high: number; label: string }>;
    insurance: { low: number; high: number };
  }

  const dataEl = document.getElementById('cc-data');
  const data: CalculatorData = JSON.parse(dataEl?.textContent ?? '{}');

  const fmt = (n: number) => `$${n.toLocaleString('en-AU')}`;

  function render() {
    const destinationSlug = (document.getElementById('cc-destination') as HTMLSelectElement).value;
    const priceBandKey = (document.getElementById('cc-price-band') as HTMLSelectElement).value;
    const results = document.getElementById('cc-results');
    if (!results) return;

    const destination = data.destinations.find((d) => d.slug === destinationSlug);
    const band = data.priceBands[priceBandKey];
    if (!destination || !band) return;

    const totalLow = band.low + destination.flightLowAUD + data.insurance.low;
    const totalHigh = band.high + destination.flightHighAUD + data.insurance.high;
    const totalDays = destination.typicalDurationDays + destination.bufferNights;

    results.innerHTML = `
      <div class="flex justify-between text-sm"><span class="text-charcoal-soft">Retreat program</span><span class="font-medium text-charcoal">${fmt(band.low)}–${fmt(band.high)}</span></div>
      <div class="flex justify-between text-sm"><span class="text-charcoal-soft">Return flights (${destination.name})</span><span class="font-medium text-charcoal">${fmt(destination.flightLowAUD)}–${fmt(destination.flightHighAUD)}</span></div>
      <div class="flex justify-between text-sm"><span class="text-charcoal-soft">Travel insurance</span><span class="font-medium text-charcoal">${fmt(data.insurance.low)}–${fmt(data.insurance.high)}</span></div>
      <div class="mt-2 flex justify-between border-t border-line pt-2 text-base"><span class="font-semibold text-forest-900">Estimated total (AUD)</span><span class="font-semibold text-forest-900">${fmt(totalLow)}–${fmt(totalHigh)}</span></div>
      <p class="mt-1 text-xs text-charcoal-soft">Suggested time off: around ${totalDays} days, including ${destination.bufferNights} buffer night(s) for travel.</p>
    `;
  }

  document.getElementById('cc-destination')?.addEventListener('change', render);
  document.getElementById('cc-price-band')?.addEventListener('change', render);
  render();
</script>
