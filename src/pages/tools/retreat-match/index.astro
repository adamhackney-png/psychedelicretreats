---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { QUIZ_QUESTIONS } from '../../../data/quiz-questions';
import { CATEGORY_META, isRetreatCategory } from '../../../lib/site';

const listings = (await getCollection(
  'listings',
  (entry) => entry.data.mode === 'standard' && entry.data.categories.some(isRetreatCategory),
)).map((l) => ({
  slug: l.id,
  name: l.data.name,
  categories: l.data.categories,
  destinationSlug: l.data.destinationSlug,
  priceBandAUD: l.data.priceBandAUD ?? null,
  categoryLabel: CATEGORY_META[l.data.categories[0]]?.label ?? l.data.categories[0],
}));
---

<BaseLayout
  title="Retreat Match Quiz"
  description="Answer 8 quick questions and see retreats that match your destination, modality, and budget — plus a fuller personalised shortlist by email."
>
  <Breadcrumbs items={[{ name: 'Tools', path: '/tools/retreat-match/' }, { name: 'Retreat Match Quiz', path: '/tools/retreat-match/' }]} />

  <section class="mx-auto max-w-2xl px-4 pb-6 sm:px-6 lg:px-8">
    <h1 class="font-serif text-3xl font-medium text-forest-900 sm:text-4xl">Retreat Match Quiz</h1>
    <p class="mt-3 text-charcoal-soft">
      8 quick questions. We'll show you a few matches straight away — for a fuller, personalised shortlist, we'll
      email it to you.
    </p>
  </section>

  <section class="mx-auto max-w-2xl px-4 pb-20 sm:px-6 lg:px-8">
    <div id="quiz-root" class="rounded-xl border border-line bg-white p-6" data-quiz>
      <div class="mb-4 h-1.5 w-full rounded-full bg-cream-dark">
        <div id="quiz-progress" class="h-1.5 rounded-full bg-forest-600 transition-all" style="width: 0%"></div>
      </div>
      <p id="quiz-step-label" class="text-xs font-medium text-charcoal-soft"></p>

      <div id="quiz-question-area" class="mt-3"></div>

      <div class="mt-6 flex justify-between">
        <button type="button" id="quiz-back" class="rounded-lg border border-line px-4 py-2 text-sm font-medium text-charcoal-soft hover:bg-cream-dark disabled:opacity-40">
          Back
        </button>
        <button type="button" id="quiz-next" class="rounded-lg bg-forest-600 px-5 py-2 text-sm font-semibold text-cream hover:bg-forest-700 disabled:opacity-40" disabled>
          Next
        </button>
      </div>

      <div id="quiz-results" class="hidden"></div>
    </div>
  </section>
</BaseLayout>

<script is:inline type="application/json" id="quiz-questions-data" set:html={JSON.stringify(QUIZ_QUESTIONS)} />
<script is:inline type="application/json" id="quiz-listings-data" set:html={JSON.stringify(listings)} />

<script>
  interface QuizOption { value: string; label: string; }
  interface QuizQuestion { id: string; question: string; options: QuizOption[]; usedForMatching: boolean; }
  interface ListingLite {
    slug: string;
    name: string;
    categories: string[];
    destinationSlug: string;
    priceBandAUD: string | null;
    categoryLabel: string;
  }

  const questions: QuizQuestion[] = JSON.parse(document.getElementById('quiz-questions-data')?.textContent ?? '[]');
  const listings: ListingLite[] = JSON.parse(document.getElementById('quiz-listings-data')?.textContent ?? '[]');

  const answers: Record<string, string> = {};
  let currentStep = 0;

  const questionArea = document.getElementById('quiz-question-area')!;
  const stepLabel = document.getElementById('quiz-step-label')!;
  const progress = document.getElementById('quiz-progress')!;
  const backBtn = document.getElementById('quiz-back') as HTMLButtonElement;
  const nextBtn = document.getElementById('quiz-next') as HTMLButtonElement;
  const resultsEl = document.getElementById('quiz-results')!;
  const quizRoot = document.getElementById('quiz-root')!;

  function renderStep() {
    const q = questions[currentStep];
    stepLabel.textContent = `Question ${currentStep + 1} of ${questions.length}`;
    progress.style.width = `${((currentStep) / questions.length) * 100}%`;

    questionArea.innerHTML = `
      <h2 class="text-lg font-medium text-forest-900">${q.question}</h2>
      <div class="mt-4 space-y-2" role="radiogroup" aria-label="${q.question}">
        ${q.options
          .map(
            (opt) => `
          <button type="button" data-value="${opt.value}" class="quiz-option w-full rounded-lg border px-4 py-2.5 text-left text-sm transition ${
            answers[q.id] === opt.value ? 'border-forest-600 bg-forest-50 text-forest-900' : 'border-line text-charcoal hover:bg-cream-dark'
          }">
            ${opt.label}
          </button>`,
          )
          .join('')}
      </div>
    `;

    questionArea.querySelectorAll<HTMLButtonElement>('.quiz-option').forEach((btn) => {
      btn.addEventListener('click', () => {
        answers[q.id] = btn.dataset.value ?? '';
        nextBtn.disabled = false;
        renderStep();
      });
    });

    backBtn.disabled = currentStep === 0;
    nextBtn.disabled = !answers[q.id];
    nextBtn.textContent = currentStep === questions.length - 1 ? 'See my matches' : 'Next';
  }

  function scoreListing(listing: ListingLite): number {
    let score = 0;
    if (answers.destination && answers.destination !== 'any' && listing.destinationSlug === answers.destination) score += 2;
    if (answers.modality && answers.modality !== 'any' && listing.categories.includes(answers.modality)) score += 2;
    if (answers.budget && answers.budget !== 'any' && listing.priceBandAUD === answers.budget) score += 1;
    return score;
  }

  function showResults() {
    quizRoot.querySelector('.mb-4')?.classList.add('hidden');
    stepLabel.classList.add('hidden');
    questionArea.classList.add('hidden');
    backBtn.classList.add('hidden');
    nextBtn.classList.add('hidden');
    resultsEl.classList.remove('hidden');

    const scored = listings
      .map((l) => ({ listing: l, score: scoreListing(l) }))
      .sort((a, b) => b.score - a.score)
      .slice(0, 3);

    const hasMatches = scored.some((s) => s.score > 0);
    const fallback = listings.slice(0, 3).map((l) => ({ listing: l, score: 0 }));
    const cards = (hasMatches ? scored : fallback)
      .map(
        ({ listing }) => `
        <a href="/listing/${listing.slug}/" class="block rounded-lg border border-line bg-white p-4 shadow-sm transition hover:shadow-md">
          <p class="text-xs font-semibold uppercase tracking-wide text-terracotta-600">${listing.categoryLabel}</p>
          <p class="mt-1 text-sm font-medium text-forest-900">${listing.name}</p>
        </a>`,
      )
      .join('');

    resultsEl.innerHTML = `
      <h2 class="text-xl font-medium text-forest-900">A few matches to start with</h2>
      <p class="mt-1 text-sm text-charcoal-soft">${hasMatches ? 'Based on your answers so far:' : "We didn't find an exact match — here are a few options to browse:"}</p>
      <div class="mt-4 space-y-3">${cards}</div>
      <div class="mt-8" id="quiz-newsletter"></div>
    `;

    const newsletterSlot = document.getElementById('quiz-newsletter');
    const template = document.getElementById('quiz-newsletter-template') as HTMLTemplateElement | null;
    if (newsletterSlot && template) {
      newsletterSlot.appendChild(template.content.cloneNode(true));
    }
  }

  nextBtn.addEventListener('click', () => {
    if (currentStep < questions.length - 1) {
      currentStep += 1;
      renderStep();
    } else {
      showResults();
    }
  });

  backBtn.addEventListener('click', () => {
    if (currentStep > 0) {
      currentStep -= 1;
      renderStep();
    }
  });

  renderStep();
</script>

<template id="quiz-newsletter-template">
  <div class="rounded-xl border border-line bg-forest-900 p-6 text-cream">
    <h3 class="font-serif text-lg font-medium text-cream">Get your full personalised shortlist</h3>
    <p class="mt-2 text-sm text-forest-100/90">
      The three matches above are a quick pass — pop in your email and we'll send a fuller shortlist based on all 8
      of your answers, plus our vetting notes for each.
    </p>
    <!-- MailerLite embedded form placeholder, group: "quiz" — see README for env var / embed swap instructions. -->
    <form
      class="mt-4 flex flex-col gap-2 sm:flex-row"
      action="https://assets.mailerlite.com/jsonp/0/forms/PLACEHOLDER_QUIZ_FORM_ID/subscribe"
      method="post"
    >
      <label for="quiz-email" class="sr-only">Email address</label>
      <input
        id="quiz-email"
        type="email"
        name="fields[email]"
        required
        placeholder="you@example.com"
        class="w-full flex-1 rounded-lg border-0 bg-white px-4 py-2.5 text-sm text-charcoal placeholder:text-charcoal-soft focus:outline-none focus:ring-2 focus:ring-terracotta-500"
      />
      <button type="submit" class="rounded-lg bg-terracotta-600 px-5 py-2.5 text-sm font-semibold text-cream hover:bg-terracotta-700">
        Email me my shortlist
      </button>
    </form>
  </div>
</template>
