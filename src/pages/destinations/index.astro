---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const destinations = await getCollection('destinations');
const listings = await getCollection('listings');
const countBySlug = (slug: string) => listings.filter((l) => l.data.destinationSlug === slug).length;
---

<BaseLayout
  title="Destinations — Legal Status by Country"
  description="Legal status, cost, and logistics for legal psychedelic retreat destinations, by country."
>
  <Breadcrumbs items={[{ name: 'Destinations', path: '/destinations/' }]} />

  <section class="mx-auto max-w-7xl px-4 pb-8 sm:px-6 lg:px-8">
    <h1 class="font-serif text-3xl font-medium text-forest-900 sm:text-4xl">Destinations</h1>
    <p class="mt-3 max-w-2xl text-charcoal-soft">
      Legal status changes by country and over time. Each destination page states our understanding at the time of
      publication, sourced — always verify current law before travelling.
    </p>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {destinations.map((dest) => (
        <a href={`/destinations/${dest.id}/`} class="rounded-lg border border-line bg-white p-6 shadow-sm transition hover:shadow-md">
          <h2 class="font-serif text-lg font-medium text-forest-900">{dest.data.name}</h2>
          <p class="mt-2 text-sm text-charcoal-soft">{dest.data.legalStatus.summary}</p>
          <p class="mt-3 text-xs font-medium text-forest-600">{countBySlug(dest.id)} listing{countBySlug(dest.id) === 1 ? '' : 's'}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
