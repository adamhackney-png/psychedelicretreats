---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import EnquiryForm from '../../components/EnquiryForm.astro';
import { SITE } from '../../lib/site';
---

<BaseLayout title="Contact" description="Get in touch with Psychedelic Retreats Australia.">
  <Breadcrumbs items={[{ name: 'Contact', path: '/contact/' }]} />

  <section class="mx-auto max-w-2xl px-4 pb-20 sm:px-6 lg:px-8">
    <h1 class="font-serif text-3xl font-medium text-forest-900 sm:text-4xl">Contact</h1>
    <p class="mt-3 text-charcoal-soft">
      Corrections, questions, media enquiries, or anything else — use the form below, or email us directly at{' '}
      <a href={`mailto:${SITE.contactEmail}`} class="text-forest-600 underline">{SITE.contactEmail}</a>.
      If you're a retreat or clinic operator wanting to claim or add a listing, use our{' '}
      <a href="/for-operators/" class="text-forest-600 underline">operator page</a> instead.
    </p>

    <div class="mt-8">
      <EnquiryForm kind="contact" heading="Send us a message" />
    </div>
  </section>
</BaseLayout>
