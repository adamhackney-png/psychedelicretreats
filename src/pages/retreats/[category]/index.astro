---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import ListingCard from '../../../components/ListingCard.astro';
import FilterBar from '../../../components/FilterBar.astro';
import FAQComponent from '../../../components/FAQ.astro';
import { RETREAT_CATEGORIES } from '../../../lib/site';
import { CATEGORY_COPY } from '../../../data/category-copy';
import { itemListJsonLd } from '../../../lib/seo';

export async function getStaticPaths() {
  return RETREAT_CATEGORIES.map((cat) => ({ params: { category: cat.slug } }));
}

const { category } = Astro.params;
const meta = RETREAT_CATEGORIES.find((c) => c.slug === category)!;
const copy = CATEGORY_COPY[category!] ?? { intro: meta.description, faq: [] };

const listings = (await getCollection('listings')).filter((entry) =>
  entry.data.categories.includes(category as any),
);
const destinationSlugs = [...new Set(listings.map((l) => l.data.destinationSlug))];

const relatedGuides = (await getCollection('guides', (entry) => !entry.data.draft))
  .filter((g) => g.data.cluster === 'retreats' || g.data.cluster === 'legal')
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);

const jsonLd = itemListJsonLd(listings.map((l) => ({ name: l.data.name, path: `/listing/${l.id}/` })));
---

<BaseLayout
  title={`${meta.label} — Legal Retreat Directory`}
  description={meta.description}
  jsonLd={jsonLd}
>
  <Breadcrumbs items={[{ name: 'Retreats', path: '/retreats/' }, { name: meta.label, path: `/retreats/${meta.slug}/` }]} />

  <section class="mx-auto max-w-7xl px-4 pb-8 sm:px-6 lg:px-8">
    <h1 class="font-serif text-3xl font-medium text-forest-900 sm:text-4xl">{meta.label}</h1>
    <p class="mt-3 max-w-3xl text-charcoal-soft">{copy.intro}</p>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-8 sm:px-6 lg:px-8">
    <FilterBar destinationSlugs={destinationSlugs} />
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-16 sm:px-6 lg:px-8">
    <h2 class="sr-only">Listings</h2>
    {listings.length === 0 ? (
      <p class="rounded-lg border border-line bg-white p-6 text-sm text-charcoal-soft">
        We don't have listings in this category live yet — check back soon, or{' '}
        <a href="/for-operators/" class="text-forest-600 underline">let us know if you run one</a>.
      </p>
    ) : (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {listings.map((listing) => (
          <ListingCard
            slug={listing.id}
            name={listing.data.name}
            mode={listing.data.mode}
            categoryLabel={meta.label}
            country={listing.data.country}
            destinationSlug={listing.data.destinationSlug}
            region={listing.data.region}
            priceBandAUD={listing.data.priceBandAUD}
            durationDays={listing.data.durationDays}
            featuredTier={listing.data.featuredTier}
            claimed={listing.data.claimed}
          />
        ))}
      </div>
    )}
  </section>

  {copy.faq.length > 0 && (
    <section class="mx-auto max-w-3xl px-4 pb-16 sm:px-6 lg:px-8">
      <FAQComponent items={copy.faq} />
    </section>
  )}

  {relatedGuides.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-medium">Related guides</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-3">
        {relatedGuides.map((guide) => (
          <a href={`/guides/${guide.id}/`} class="rounded-lg border border-line bg-white p-5 shadow-sm transition hover:shadow-md">
            <h3 class="font-serif text-base font-medium text-forest-900">{guide.data.title}</h3>
            <p class="mt-2 text-sm text-charcoal-soft">{guide.data.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
