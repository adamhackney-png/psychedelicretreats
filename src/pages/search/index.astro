---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
---

<BaseLayout title="Search" description="Search retreats, guides, destinations, and news across the site.">
  <Breadcrumbs items={[{ name: 'Search', path: '/search/' }]} />

  <section class="mx-auto max-w-3xl px-4 pb-20 sm:px-6 lg:px-8">
    <h1 class="font-serif text-3xl font-medium text-forest-900 sm:text-4xl">Search</h1>
    <div id="search" class="mt-8"></div>
  </section>
</BaseLayout>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script is:inline src="/pagefind/pagefind-ui.js"></script>
<script is:inline>
  window.addEventListener('DOMContentLoaded', () => {
    if (typeof PagefindUI === 'undefined') return;
    const ui = new PagefindUI({ element: '#search', showSubResults: true });
    const q = new URLSearchParams(location.search).get('q');
    if (q) ui.triggerSearch(q);
  });
</script>
