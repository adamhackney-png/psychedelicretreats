---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import EnquiryForm from '../../components/EnquiryForm.astro';

const tiers = [
  {
    name: 'Free listing',
    price: 'Free',
    description: 'Every eligible operator gets a factual, sourced listing at no cost.',
    features: ['Standard listing page', 'Vetting checklist', 'Editable via claim'],
  },
  {
    name: 'Featured',
    price: '$79/mo or $790/yr',
    description: 'Priority placement in category and destination pages.',
    features: ['Everything in Free', '"Featured" badge', 'Priority placement in category listings', 'Enquiry form enabled'],
  },
  {
    name: 'Premium Partner',
    price: '$199/mo or $1,990/yr',
    description: 'Top placement plus deeper visibility across the site.',
    features: ['Everything in Featured', '"Premium Partner" badge', 'Top placement in category & home page rotation', 'Inclusion in relevant guides where editorially appropriate'],
  },
];
---

<BaseLayout
  title="For Operators — List Your Retreat or Service"
  description="Claim your free listing or upgrade to Featured or Premium Partner. No online payment — we invoice manually after your enquiry."
>
  <Breadcrumbs items={[{ name: 'For Operators', path: '/for-operators/' }]} />

  <section class="mx-auto max-w-7xl px-4 pb-8 sm:px-6 lg:px-8">
    <h1 class="font-serif text-3xl font-medium text-forest-900 sm:text-4xl">For Operators</h1>
    <p class="mt-3 max-w-2xl text-charcoal-soft">
      We list legally-operating retreats and services with sourced, factual information. Claim your free listing,
      or enquire about Featured or Premium Partner placement below. There's no online payment — submit the form
      and we'll follow up to invoice manually.
    </p>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-16 sm:px-6 lg:px-8">
    <div class="grid gap-6 md:grid-cols-3">
      {tiers.map((tier) => (
        <div class="flex flex-col rounded-xl border border-line bg-white p-6 shadow-sm">
          <h2 class="font-serif text-xl font-medium text-forest-900">{tier.name}</h2>
          <p class="mt-1 text-lg font-semibold text-terracotta-600">{tier.price}</p>
          <p class="mt-2 text-sm text-charcoal-soft">{tier.description}</p>
          <ul class="mt-4 flex-1 space-y-2 text-sm text-charcoal">
            {tier.features.map((feature) => (
              <li class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-4 w-4 flex-none text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <p class="mt-6 text-xs text-charcoal-soft">
      Featured/Premium Partner tier placement never changes vetting checklist ratings or factual accuracy — see our{' '}
      <a href="/editorial-policy/" class="underline">editorial policy</a>.
    </p>
  </section>

  <section id="claim" class="mx-auto max-w-2xl px-4 pb-20 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-medium">Claim your listing or enquire about a tier</h2>
    <p class="mt-2 text-sm text-charcoal-soft">
      Tell us who you are and what you need — claiming an existing listing, adding a new one, or upgrading to
      Featured/Premium Partner.
    </p>
    <div class="mt-6">
      <EnquiryForm kind="claim" heading="Claim / operator enquiry" />
    </div>
  </section>
</BaseLayout>
