---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { RETREAT_CATEGORIES } from '../lib/site';

// Placeholder data for Phase 1 scaffold — replaced by live content collections in Phase 2/3.
const featuredRetreats = [
  { name: 'Beckley Retreats — Netherlands', location: 'Netherlands', category: 'Psilocybin', price: '$3,000–$6,000 AUD', href: '/listing/beckley-retreats-netherlands/' },
  { name: 'Beckley Retreats — Jamaica', location: 'Jamaica', category: 'Psilocybin', price: '$3,000–$6,000 AUD', href: '/listing/beckley-retreats-jamaica/' },
  { name: 'Temple of the Way of Light', location: 'Peru', category: 'Ayahuasca', price: 'Under $3,000 AUD', href: '/listing/temple-of-the-way-of-light/' },
  { name: 'Rythmia Life Advancement Center', location: 'Costa Rica', category: 'Luxury / Ayahuasca', price: '$10,000+ AUD', href: '/listing/rythmia/' },
  { name: 'Alchemy Retreats', location: 'Netherlands', category: 'Psilocybin', price: '$3,000–$6,000 AUD', href: '/listing/alchemy-retreats/' },
  { name: 'The Buena Vida', location: 'Byron Bay, Australia', category: 'Breathwork', price: 'Under $3,000 AUD', href: '/listing/the-buena-vida/' },
];

const latestNews = [
  { title: 'TGA update: what changed (and what didn’t) for authorised prescribers in 2026', date: '2026-06-30', href: '/news/tga-update-2026/' },
  { title: 'Netherlands truffle retreat regulation: what Australians should know before booking', date: '2026-06-18', href: '/news/netherlands-truffle-regulation/' },
  { title: 'New Peruvian safety accreditation scheme for ayahuasca centres', date: '2026-06-02', href: '/news/peru-safety-accreditation/' },
  { title: 'Medicare and psychedelic-assisted therapy: the current state of rebates', date: '2026-05-20', href: '/news/medicare-pat-rebates/' },
];
---

<BaseLayout
  title="Psychedelic Retreats Australia — Independent Directory & Guides"
  description="An independent Australian directory and information hub for legal psychedelic retreats abroad, Australian clinical services, breathwork retreats, and integration support."
>
  <!-- Hero -->
  <section class="border-b border-line bg-cream">
    <div class="mx-auto grid max-w-7xl gap-10 px-4 py-16 sm:px-6 md:grid-cols-2 md:items-center md:py-24 lg:px-8">
      <div>
        <p class="font-sans text-sm font-semibold uppercase tracking-wide text-terracotta-600">Independent · Australian · Evidence-aware</p>
        <h1 class="mt-3 font-serif text-4xl font-medium leading-tight text-forest-900 sm:text-5xl">
          Find a legal psychedelic retreat, informed by facts, not hype.
        </h1>
        <p class="mt-5 max-w-xl text-lg leading-relaxed text-charcoal-soft">
          We vet and catalogue legal psychedelic retreats abroad, Australian clinical pathways, and breathwork
          and integration support — with sourced facts, not promotional claims.
        </p>

        <form action="/retreats/" method="get" class="mt-8 flex max-w-lg flex-col gap-2 sm:flex-row">
          <label for="hero-search" class="sr-only">Search retreats</label>
          <input
            id="hero-search"
            type="text"
            name="q"
            placeholder="Search destinations, modalities, or retreat names…"
            class="w-full flex-1 rounded-lg border border-line bg-white px-4 py-3 text-sm text-charcoal shadow-sm placeholder:text-charcoal-soft/60 focus:outline-none focus:ring-2 focus:ring-forest-500"
          />
          <button type="submit" class="rounded-lg bg-forest-600 px-6 py-3 text-sm font-semibold text-cream shadow-sm transition hover:bg-forest-700">
            Search
          </button>
        </form>

        <div class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-sm text-charcoal-soft">
          <span class="flex items-center gap-1.5"><span class="h-1.5 w-1.5 rounded-full bg-forest-500"></span>Independent</span>
          <span class="flex items-center gap-1.5"><span class="h-1.5 w-1.5 rounded-full bg-forest-500"></span>No underground listings</span>
          <span class="flex items-center gap-1.5"><span class="h-1.5 w-1.5 rounded-full bg-forest-500"></span>Evidence-aware</span>
        </div>
      </div>

      <div class="aspect-[4/3] w-full rounded-xl border border-line bg-gradient-to-br from-forest-100 to-terracotta-100 shadow-sm" role="img" aria-label="Landscape imagery placeholder — editorial retreat photography">
      </div>
    </div>
  </section>

  <!-- Featured retreats -->
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between gap-4">
      <h2 class="text-2xl font-medium sm:text-3xl">Featured retreats</h2>
      <a href="/retreats/" class="text-sm font-medium text-forest-600 hover:text-forest-700">Browse all retreats →</a>
    </div>

    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featuredRetreats.map((retreat) => (
        <a href={retreat.href} class="group overflow-hidden rounded-lg border border-line bg-white shadow-sm transition hover:shadow-md">
          <div class="aspect-[16/10] w-full bg-gradient-to-br from-forest-100 to-cream-dark"></div>
          <div class="p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-terracotta-600">{retreat.category}</p>
            <h3 class="mt-1 font-serif text-lg font-medium text-forest-900 group-hover:underline">{retreat.name}</h3>
            <p class="mt-1 text-sm text-charcoal-soft">{retreat.location}</p>
            <p class="mt-3 text-sm font-medium text-charcoal">{retreat.price}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Category tiles -->
  <section class="border-y border-line bg-cream-dark/50">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-medium sm:text-3xl">Browse by category</h2>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {RETREAT_CATEGORIES.map((cat) => (
          <a href={`/retreats/${cat.slug}/`} class="rounded-lg border border-line bg-white p-6 shadow-sm transition hover:shadow-md">
            <h3 class="font-serif text-lg font-medium text-forest-900">{cat.label}</h3>
            <p class="mt-2 text-sm text-charcoal-soft">{cat.description}</p>
          </a>
        ))}
      </div>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        <a href="/clinics/ketamine/" class="rounded-lg border border-line bg-white p-6 shadow-sm transition hover:shadow-md">
          <h3 class="font-serif text-lg font-medium text-forest-900">Ketamine Clinics (Australia)</h3>
          <p class="mt-2 text-sm text-charcoal-soft">Australian clinical ketamine services — factual, neutral-mode listings.</p>
        </a>
        <a href="/clinics/psychedelic-assisted-therapy/" class="rounded-lg border border-line bg-white p-6 shadow-sm transition hover:shadow-md">
          <h3 class="font-serif text-lg font-medium text-forest-900">Psychedelic-Assisted Therapy (Australia)</h3>
          <p class="mt-2 text-sm text-charcoal-soft">Authorised prescriber pathway services — factual, neutral-mode listings.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Latest news -->
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between gap-4">
      <h2 class="text-2xl font-medium sm:text-3xl">Latest news</h2>
      <a href="/news/" class="text-sm font-medium text-forest-600 hover:text-forest-700">All news →</a>
    </div>
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {latestNews.map((item) => (
        <a href={item.href} class="rounded-lg border border-line bg-white p-5 shadow-sm transition hover:shadow-md">
          <time class="text-xs font-medium text-charcoal-soft" datetime={item.date}>
            {new Date(item.date).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' })}
          </time>
          <h3 class="mt-2 text-sm font-medium leading-snug text-forest-900">{item.title}</h3>
        </a>
      ))}
    </div>
  </section>

  <!-- Lead magnet -->
  <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
    <NewsletterSignup />
  </section>
</BaseLayout>
